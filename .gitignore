# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/
build/
dist/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.ipynb_checkpoints/

# Environments (we use the `f_f` conda env, python=3.13 — not committed)
.env
.venv/
venv/
env/

# --- Secrets / credentials (never commit) ---
# FIRMS MAP_KEY, ACLED key, Copernicus account, GEE service-account JSON, etc.
# Ignore the whole secrets/ dir: service-account keys carry arbitrary filenames
# (e.g. <project>-<hash>.json) that the patterns below would miss.
secrets/
*.key
*credentials*.json
*service-account*.json
secrets.*
.earthengine/
secrets\rich-stratum-429021-u4-a0736597d906.json

# --- Cached external pulls (STRUCTURE.md §9 — cached/checkpointed, reproducible) ---
# Pulls are reproducible from pinned sources; don't bloat the repo.
cache/
**/cache/
*.cache
# GEE tiled-download + screen caches (regenerable reproducibility checkpoints):
# aois/_mask_tiles, baseline/_ndvi_tiles, pipelines/floods/_flood_tiles, etc.
**/_*_tiles/
.checkpoints/

# --- Large rasters / geospatial binaries ---
# Generated artifacts (W1/W2/W4/W5) — regenerated from code, not version-controlled.
*.tif
*.tiff
*.img
*.nc
*.hdf
*.grib
*.grib2
*.zip
*.tar
*.tar.gz

# Heavy outputs — keep tables/figures tracked selectively if small; ignore by default
outputs/**/*.tif
outputs/**/*.tiff
outputs/**/*.png
outputs/**/*.jpg

# --- OS / editor cruft ---
.DS_Store
Thumbs.db
.vscode/
.idea/
secrets/g_auth.json
